{
  "manifest_version": 3,
  "name": "My App: Kleinanzeigen Sync",
  "version": "1.0.0",
  "description": "Sync items from The Photo App to Kleinanzeigen listing form",
  "permissions": ["storage", "activeTab", "tabs", "unlimitedStorage", "debugger"],
  "host_permissions": [
    "https://www.kleinanzeigen.de/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "http://192.168.178.61:8000/*",
    "https://awwahpecfvdljgupnzft.supabase.co/*",
    "https://awwahpecfvdljgupnzft.supabase.in/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.kleinanzeigen.de/p-anzeige-aufgeben*",
        "https://www.kleinanzeigen.de/p-anzeige-aufgeben-schritt2*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://www.kleinanzeigen.de/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}