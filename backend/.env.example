SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=sb_publishable_your_publishable_key_here
SUPABASE_JWT_SECRET=your-jwt-secret-uuid
GEMINI_API_KEY=your_gemini_api_key_here
SUPABASE_API_KEY=sb_secret_your_secret_key_here
DEEPSEEK_API_KEY=sk-your_deepseek_key_here
service_role=your_service_role_jwt_here

# Connect to Supabase via connection pooling (use for regular queries)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database (use for migrations / DDL)
DIRECT_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres
